<%@ page language="java" contentType="text/html; charset=UTF-8"
    pageEncoding="UTF-8"%>
<!--
	session 의 속성 사용
		- 한번 생성된 세션은 종료되기 전까지 지속적으로 유지됨
		따라서 웹 어플리케이션을 실행하는 동안 지속적으로 사용하는
		데이터의 저장소로 세션이 적당함

  -->    
<%

	session.setAttribute("MEMBERID","aaa");
	session.setAttribute("NAME", "홍길동");
%>
    
    
<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title></title>
</head>
세션 정보를 저장하였습니다.
</body>
</html>