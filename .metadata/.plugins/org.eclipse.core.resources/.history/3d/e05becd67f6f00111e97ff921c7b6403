<%@ page language="java" contentType="text/html; charset=UTF-8"
    pageEncoding="UTF-8"%>
<% request.setCharacterEncoding("utf-8"); %>
<%@ taglib prefix="c" uri = "http://java.sun.com/jsp/jstl/core" %>



<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>회원가입 확인</title>
	<link href="style.css" type="text/css" rel="stylesheet">
</head>
<body bgcolor="#ffffcc">
	<c:set var="flag" value="${flag }"></c:set>
		<br>
			<div align="center">
			<c:choose>
				<c:when test="${flag }">
					<br>회원가입을 축하드립니다.
					<meta http-equiv='refresh' content='2;url=member.mdo?cmd=login'>
				</c:when>
				<c:otherwise>
					<b>회원가입에 실패. 다시 입력;
					<a href='member.mdo?cmd=regForm'>다시 가입</a>;
				</c:otherwise>
				</c:choose>
			</div>
		</body>
</html>