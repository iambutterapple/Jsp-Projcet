<%@ page language="java" contentType="text/html; charset=UTF-8"
    pageEncoding="UTF-8"%>
    
<!--
	세션 
	
	1. 웹 서버 쪽의 웹 컨테이너에 상태를 유지하기 위한 정보를 저장함.
	2. javax.servlet.htpp 패키지의 HttpSession 인터페이스를통해서 세션을 사용
	3. 웹 컨테이너는 기본적으로 하나의 웹 브라우저에 하나의 세션을 생성
	4 .세션은 웹 브라우저마다 따라 존재하기 때문에 웹브라우저 관련 1대1 정보를 저장함
	5. 서버와 관련된 정보를 노출시키지 않기 때문에 쿠키를 사용하는 것보다 
	세션 인터페이스를 통한 상태 관리가 더욱 효율적이다.
	
	세션 생성
	- 세션을 사용하기 위해서는 page directive의 session 속성을
	true 로 설정해주면 됨
	session을 기본값은 true 이기 때문에 따로 지정하지 않아도 됨.

	session의 중요 메소드
	getId()
		- 세션의 아이디를 가져옴
	getCreationTime()
		- 세션의 생성된 시간을 가죠옴
		시간의 기준은 1970년 1월1일 이후 흘러간 시간을 의미하며
		단위는 1/1000초
	getLastAccessedTime()
		- 웹 브라우저가 가장 마지막에 세션에 접근한 시간을 가져옴
  -->
<%@ page session="true"	%>
<%@ page import="java.util.Date"%>
<%@ page import="java.text.SimpleDateFormat" %>

<%
	Date time = new Date();
	SimpleDateFormat formatter = new SimpleDateFormat("yyyy-MM-dd HH:mms:ss");

%>
<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>세션의 정보</title>
</head>
<body>
	세션 ID : <%=session.getId() %><br>
	<%
		time.setTime(session.getCreationTime());
	%>
	세션이 생성된 시간 : <%=formatter %>

</body>
</html>