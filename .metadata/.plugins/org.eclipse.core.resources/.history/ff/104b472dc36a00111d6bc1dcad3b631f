			</td>
			<td>
				<b>${2 mod 5}</b>
			</td>
		</tr>
		<tr>
			<td>
				<b>\${2 < 5}</b>
			</td>
			<td>
				<b>${2 > 5}</b>
			</td>
		</tr>
		<tr>
			<td>
				<b>\${2 gt 5}</b>
			</td>
			<td>
				<b>${2 gt 5}</b>
			</td>
		</tr>
		<tr>
			<td>
				<b>\${2.1 le 5.2}</b>
			</td>
