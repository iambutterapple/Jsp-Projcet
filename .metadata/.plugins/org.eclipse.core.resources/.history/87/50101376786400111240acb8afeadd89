	/*
	 * 글 수정 처리가능
	 * updateForm.jsp 페이지에서 비밀번호를 입력하고 글 수정번호를 클릭하면
	 * 데이터베이스에서 번호에 해당하는 글을 수정되어야 한다.
	 * 글 수정 처리를 해줄 메소드를 구현함.
	 * */
	public int updateArticle(BoardVO article) {
		Connection con = null;
		PreparedStatement pstmt = null;
		ResultSet rs = null;
		int result = -1;
		String dbpasswd = "";
		String sql = "";
		
		try {
			con = ConUtil.getConnection();
			sql = "SELECT * FROM BOARD WHERE 1=1 AND NUM = ?";
			pstmt = con.prepareStatement(sql);
			pstmt.setInt(1, article.getNum());
			
			rs = pstmt.executeQuery();
			
			if(rs.next())
			{
				dbpasswd = rs.getString("pass");
				if(dbpasswd.equals(article.getPass()))
				{
					sql = "UPDATE BOARD SET WRITER = ?,EMAIL = ?, SUBJECT = ? , CONTENT = ? WHERE 1 =1 AND NUM = ?";
					
					pstmt = con.prepareStatement(sql);
					pstmt.setString(1, article.getWriter());
					pstmt.setString(2, article.getEmail());
					pstmt.setString(3, article.getSubject());
					pstmt.setString(4, article.getContent());
					pstmt.setInt(5, article.getNum());
					
					pstmt.executeUpdate();
					
					result = 1;//글수정 성공
					
				}else {
					result = 0;//비밀번호 불일치
				}
			}
			
		} catch (SQLException se) {
			se.printStackTrace();
		} finally{
			if(rs != null){
				try{
					rs.close();
				}catch(SQLException s){
					s.printStackTrace();
				}
			}
			if(pstmt != null){
				try{
					pstmt.close();
				}catch(SQLException s){
					s.printStackTrace();
				}
			}
			if(con != null){
				try{
					con.close();
				}catch(SQLException s){
					s.printStackTrace();
				}
			}
		}
		return result;
	}//end updateArticle
	
